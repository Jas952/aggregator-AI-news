# Telegram API credentials
# Get from: https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH="your_api_hash_here"

# Midjourney API credentials
# Get from: Browser cookies after logging in to midjourney.com
MJ_AUTH_TOKEN="your_midjourney_jwt_token_here"
CF_CLEARANCE="your_cloudflare_clearance_cookie_here"

# Application settings
REFRESH_INTERVAL_HOURS=5

# Telegram Notifier (optional)
# For receiving user suggestions via Telegram bot
# Create bot: @BotFather on Telegram
TELEGRAM_NOTIFIER_BOT_TOKEN="your_bot_token_here"
TELEGRAM_NOTIFIER_CHAT_ID="your_chat_id_here"

# Telegram Log Monitor (optional)
# For monitoring system status, errors, and refresh notifications
# Uses the same bot as above or create a separate one
TELEGRAM_LOGS_API="your_bot_token_here"
TELEGRAM_LOGS_CHANNEL="your_chat_id_here"
